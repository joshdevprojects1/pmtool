DATABASE_URL=postgres://pmtool:pmtool@localhost:5433/pmtool
PORT=8080
# token:workspace_uuid pairs, comma separated
API_TOKENS=dev-token:00000000-0000-0000-0000-000000000001
# per-org ingest secrets: org_connection_uuid:secret pairs
INGEST_SECRETS=00000000-0000-0000-0000-0000000000aa:dev-secret

# --- Salesforce connected app (OAuth) ---
# Create in Salesforce: Setup -> App Manager -> New Connected App.
# Enable OAuth, callback URL http://localhost:8080/v1/orgs/callback,
# scopes: "Manage user data via APIs (api)" and
# "Perform requests at any time (refresh_token, offline_access)".
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_LOGIN_URL=https://login.salesforce.com
APP_BASE_URL=http://localhost:8080
# 32-byte hex key for refresh-token encryption at rest. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENC_KEY=

# --- dev-only worker auth fallbacks (used when an org has no OAuth token) ---
# SF_CLI_ALIAS=devorg
# SF_ACCESS_TOKEN=
# SF_INSTANCE_URL=
